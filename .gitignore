src/api/func/tests/testing_images/horses_detected.jpg
src/api/func/tests/testing_images/IA_ejecutada_en_entorno_propio.PNG
src/api/func/tests/testing_images/script_de_desecho.py

# NOTA: pytest.ini, .prettierrc y package-lock.json AHORA se versionan
